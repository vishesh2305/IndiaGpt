# AI Provider (Groq for testing)
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/indiagpt?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Maps (client-side for map rendering)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Google Maps (server-side for geocoding, places, directions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
